{
  "name": "@asterpay/mcp-server",
  "version": "0.1.0-beta.1",
  "description": "MCP server for AI agents to discover and buy from European merchants via x402 + EUR settlement",
  "private": false,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "asterpay-mcp": "./dist/index.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "postbuild": "node -e \"try{require('fs').chmodSync('dist/index.js',0o755)}catch{}\"",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "mcp-server",
    "x402",
    "asterpay",
    "eur",
    "agent",
    "agentic-commerce",
    "agentic-payments",
    "sepa",
    "settlement",
    "m2v"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/asterpay/mcp-server"
  },
  "homepage": "https://asterpay.io",
  "bugs": {
    "url": "https://github.com/asterpay/mcp-server/issues"
  },
  "author": "AELIRA LTD",
  "license": "Apache-2.0",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "zod": "^3.24.3"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
